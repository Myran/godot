elif env['platform'] == 'windows':
    print("Firebase: Windows platform")
    # Link Firebase C++ SDK libraries for Windows (MSVC)
    # Libraries built with VS2019/MT (static runtime) for x64
    # NOTE: Always use Release libs - Debug libs (/MTd) incompatible with Godot's debug_crt=/MDd (Task-434)
    if env['arch'] == 'x86_64':
        lib_variant = 'Release'
        print("Firebase: Using " + lib_variant + " libraries for all Windows targets")

        lib_base = "#/../firebase/firebase_cpp_sdk/libs/windows/VS2019/MT/x64/" + lib_variant + "/"
        env.Prepend(LIBS=[File(lib_base + "firebase_app.lib")])
        env.Prepend(LIBS=[File(lib_base + "firebase_analytics.lib")])
        env.Prepend(LIBS=[File(lib_base + "firebase_remote_config.lib")])
        env.Prepend(LIBS=[File(lib_base + "firebase_database.lib")])
        env.Prepend(LIBS=[File(lib_base + "firebase_firestore.lib")])
        env.Prepend(LIBS=[File(lib_base + "firebase_auth.lib")])
        env.Prepend(LIBS=[File(lib_base + "firebase_functions.lib")])
        env.Prepend(LIBS=[File(lib_base + "firebase_messaging.lib")])
        # Windows system libraries required by Firebase SDK (Task-434)
        # Use LINKFLAGS to pass system libraries directly to linker (avoids SCons name mangling)
        # Reference: https://firebase.google.com/docs/database/cpp/start

        # Core Firebase libraries (all services)
        env.Append(LINKFLAGS=['advapi32.lib'])  # Windows advanced API (cryptography, registry)
        env.Append(LINKFLAGS=['ws2_32.lib'])    # Windows Sockets (CRITICAL: RTDB desktop uses REST API)
        env.Append(LINKFLAGS=['crypt32.lib'])   # Cryptography API (auth/tokens)

        # Realtime Database specific libraries
        env.Append(LINKFLAGS=['iphlpapi.lib'])  # IP Helper API (network operations)
        env.Append(LINKFLAGS=['psapi.lib'])     # Process Status API
        env.Append(LINKFLAGS=['Userenv.lib'])   # User Environment/Profile ( GetUserProfileDirectoryW)

        # Firestore specific
        env.Append(LINKFLAGS=['dbghelp.lib'])   # Debug Help (SymSetOptions, SymInitialize)

        # ICU libraries for timezone/locale functions (u_errorName, ucal_getTimeZoneIDForWindowsID)
        # Windows 10 1903+ uses icu.lib, older versions use icuuc.lib + icuin.lib
        env.Append(LINKFLAGS=['icu.lib'])       # Modern unified ICU library (Windows 10 1903+)
    else:
        print('WARN: Unsupported architecture for Firebase Windows: ' + env['arch'] + ' (only x86_64 supported)')
