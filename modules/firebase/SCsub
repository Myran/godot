# SCsub
Import('env')

print("Firebase SCsub: platform=" + env['platform'] + ", arch=" + env['arch'])

# Platform-specific source file selection
# - Windows: Use firebase_windows.cpp (MSVC can't compile .mm Objective-C++ files)
# - All other platforms (Android/iOS/macOS): Use firebase.mm (contains platform-specific code
#   for Android JNI, iOS UIKit, and macOS NSBundle via preprocessor directives)

# Shared C++ source files (all platforms)
env.add_source_files(env.modules_sources, "convertor.cpp")
env.add_source_files(env.modules_sources, "database.cpp")
env.add_source_files(env.modules_sources, "messaging.cpp")
env.add_source_files(env.modules_sources, "register_types.cpp")
env.add_source_files(env.modules_sources, "remote_config.cpp")

# Platform-specific Firebase initialization
if env['platform'] == 'windows':
    # Windows: Use dedicated Windows implementation
    env.add_source_files(env.modules_sources, "firebase_windows.cpp")
else:
    # Android/iOS/macOS: Use .mm file (Android compiler handles .mm, just ignores Obj-C parts)
    env.add_source_files(env.modules_sources, "*.mm")

env.Append(CPPPATH="#/../firebase/firebase_cpp_sdk/include")

if env['platform'] == 'iphone':
    print("Firebase: iOS platform")
    # Link Firebase C++ SDK libraries for iOS
    env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/ios/device-arm64/libfirebase_app.a")])
    env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/ios/device-arm64/libfirebase_analytics.a")])
    env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/ios/device-arm64/libfirebase_remote_config.a")])
    env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/ios/device-arm64/libfirebase_database.a")])
    env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/ios/device-arm64/libfirebase_auth.a")])
    env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/ios/device-arm64/libfirebase_functions.a")])
    env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/ios/device-arm64/libfirebase_messaging.a")])

elif env['platform'] == 'macos':
    print("Firebase: macOS platform")
    # Link Firebase C++ SDK libraries for macOS (darwin)
    if env['arch'] == 'arm64':
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/arm64/libfirebase_app.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/arm64/libfirebase_analytics.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/arm64/libfirebase_remote_config.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/arm64/libfirebase_database.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/arm64/libfirebase_auth.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/arm64/libfirebase_functions.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/arm64/libfirebase_messaging.a")])
    elif env['arch'] == 'x86_64':
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/x86_64/libfirebase_app.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/x86_64/libfirebase_analytics.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/x86_64/libfirebase_remote_config.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/x86_64/libfirebase_database.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/x86_64/libfirebase_auth.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/x86_64/libfirebase_functions.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/darwin/x86_64/libfirebase_messaging.a")])
    else:
        print('WARN: Unsupported architecture for Firebase macOS: ' + env['arch'])

elif env['platform'] == 'android':
    print("Firebase: Android platform")
    if env['arch'] == 'arm32':
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/android/armeabi-v7a/libfirebase_app.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/android/armeabi-v7a/libfirebase_analytics.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/android/armeabi-v7a/libfirebase_remote_config.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/android/armeabi-v7a/libfirebase_database.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/android/armeabi-v7a/libfirebase_auth.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/android/armeabi-v7a/libfirebase_functions.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/android/armeabi-v7a/libfirebase_messaging.a")])
    elif env['arch'] == 'arm64':
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/android/arm64-v8a/libfirebase_app.a")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/android/arm64-v8a/libfirebase_analytics.a")])
