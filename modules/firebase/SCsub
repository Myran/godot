elif env['platform'] == 'windows':
    print("Firebase: Windows platform")
    # Link Firebase C++ SDK libraries for Windows (MSVC)
    # Libraries built with VS2019/MT (static runtime) for x64
    if env['arch'] == 'x86_64':
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/windows/VS2019/MT/x64/Release/firebase_app.lib")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/windows/VS2019/MT/x64/Release/firebase_analytics.lib")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/windows/VS2019/MT/x64/Release/firebase_remote_config.lib")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/windows/VS2019/MT/x64/Release/firebase_database.lib")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/windows/VS2019/MT/x64/Release/firebase_firestore.lib")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/windows/VS2019/MT/x64/Release/firebase_auth.lib")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/windows/VS2019/MT/x64/Release/firebase_functions.lib")])
        env.Prepend(LIBS=[File("#/../firebase/firebase_cpp_sdk/libs/windows/VS2019/MT/x64/Release/firebase_messaging.lib")])
        # Windows system libraries required by Firebase SDK
        # Use LINKFLAGS to pass system libraries directly to linker (avoids SCons name mangling)
        env.Append(LINKFLAGS=['Userenv.lib'])  # For GetUserProfileDirectoryW (used by firebase_database)
        # ICU libraries for timezone/locale functions (u_errorName, ucal_getTimeZoneIDForWindowsID)
        # Windows 10 1903+ uses icu.lib, older versions use icuuc.lib + icuin.lib
        env.Append(LINKFLAGS=['icu.lib'])      # Modern unified ICU library (Windows 10 1903+)
    else:
        print('WARN: Unsupported architecture for Firebase Windows: ' + env['arch'] + ' (only x86_64 supported)')
