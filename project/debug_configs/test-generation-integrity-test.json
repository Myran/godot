{
  "description": "Test Generation Integrity Test - Validates semantic log capture and test config generation workflow",
  "actions": [
    "system.debug.registry_stats",
    "game.lineup.populate_enemy",
    "game.test.simple_player_events",
    "system.debug.quit_application"
  ],
  "integrity_validation": {
    "test_type": "test_generation_integrity",
    "workflow_stages": [
      "semantic_logging_active",
      "session_id_generation",
      "action_capture",
      "log_parsing",
      "config_generation",
      "replay_validation"
    ],
    "validation_criteria": {
      "session_logging": "session_id_present_in_logs",
      "semantic_actions": "player_actions_captured",
      "log_structure": "valid_json_structure",
      "config_format": "valid_debug_config_schema",
      "replay_ready": "generated_config_executable"
    }
  }
}