# Help system for GameTwo Development Environment

# Show WezTerm configuration for universal clickable just commands
help-wezterm-config:
    #!/usr/bin/env bash
    echo "🔧 WezTerm Configuration for Universal Clickable Just Commands"
    echo "============================================================="
    echo ""
    echo ""
    echo "Add this to your ~/.wezterm.lua config file:"
    echo ""
    echo "local wezterm = require 'wezterm'"
    echo "local config = {}"
    echo ""
    echo "-- Universal hyperlink rules for just commands"
    echo "config.hyperlink_rules = {"
    echo "  -- AUTO-DETECT: Make any 'just command-name [arguments]' text clickable"
    echo "  {"
    echo "    regex = '\\\\bjust ([a-zA-Z0-9._-]+(?:\\\\s+[^\\\\s#][^#]*?)??)(?=\\\\s*#|\\\\s*\$)',"
    echo "    format = 'just://\$1',"
    echo "    highlight = 1,"
    echo "  },"
    echo "  -- Keep existing URL support"
    echo "  {"
    echo "    regex = '\\\\b\\\\w+://\\\\S+[)/a-zA-Z0-9-_]',"
    echo "    format = '\$0',"
    echo "  },"
    echo "}"
    echo ""
    echo "-- Handle just:// protocol clicks"
    echo "wezterm.on('open-uri', function(window, pane, uri)"
    echo "  if uri:find('^just://') then"
    echo "    local cmd = uri:gsub('^just://', '')"
    echo "    window:perform_action("
    echo "      wezterm.action.SendString('just ' .. cmd .. '\\r'),"
    echo "      pane"
    echo "    )"
    echo "    return false"
    echo "  end"
    echo "  return true"
    echo "end)"
    echo ""
    echo "return config"
    echo ""
    echo "🎯 WHAT THIS ENABLES:"
    echo "✅ ALL help commands become clickable automatically"
    echo "✅ Commands WITH arguments: 'just logs test_123' → fully clickable"
    echo "✅ Quoted arguments: 'just test-android \\'system.*\\'' → fully clickable"
    echo "✅ Error messages with 'just validate-gdscript' become clickable"
    echo "✅ Documentation with any just commands → clickable"
    echo "✅ Future commands automatically supported"
    echo "✅ Zero maintenance required"
    echo ""
    echo "💡 After adding this config:"
    echo "1. Restart WezTerm"
    echo "2. Run ANY help command (just help-debug, just help-logs, etc.)"
    echo "3. Click any 'just' command to execute it!"

# Legacy non-interactive help (text-only fallback)
help-static:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "🚀 GameTwo Development Environment (Static)"
    echo "==========================================="
    echo "💡 Use 'just help' for interactive clickable commands!"
    echo ""
    echo "🏗️  SMART BUILD COMMANDS (Recommended)"
    echo "  just build-all-android           # Android smart rebuild (3-5 min, was 20+ min)"
    echo "  just fastbuild-android           # Android fast build (30-60 sec)"
    echo ""
    echo "📱 DEPLOY (Development - export → install → run)"
    echo "  just deploy-android              # Deploy to Android device"
    echo "  just deploy-ios                  # Deploy to iOS (default: iPad)"
    echo "  just deploy-macos                # Deploy to macOS (export + run)"
    echo "  just deploy-windows              # Deploy to Windows physical machine"
    echo ""
    echo "🚀 SHIP (Production - App Store)"
    echo "  just ship-android                # Ship to Play Store (internal track)"
    echo "  just ship-android production     # Ship to Play Store (production track)"
    echo "  just ship-android internal yes   # First upload to track (draft mode)"
    echo "  just ship-ios                    # Ship to App Store"
    echo ""
    echo "🔄 SHIP PIPELINES (export → test → ship)"
    echo "  just pipeline-ship               # Export → test → ship (15-30 min)"
    echo "  just pipeline-ship production    # Ship to production track"
    echo "  just pipeline-rebuild-ship       # Rebuild → export → test → ship (45-90 min)"
    echo ""
    echo "🧹 CLEAR TEST CONFIG (before deploy to avoid stale tests)"
    echo "  just clear-test-android          # Clear Android device config"
    echo "  just clear-test-ios              # Clear iOS export config"
    echo "  just clear-test-macos            # Clear macOS config"
    echo "  just clear-test-windows-physical # Clear Windows config"
    echo ""
    echo "🔥 FORCE REBUILD (When Needed)"
    echo "  just rebuild-all-android         # Force complete Android rebuild (30-40 min)"
    echo "  just rebuild-all-ios             # Force complete iOS rebuild (30-40 min)"
    echo ""
    echo "🔧 INDIVIDUAL COMPONENT REBUILD"
    echo "  just build-swappy force=yes      # Force rebuild Swappy libraries (5-8 min)"
    echo "  just build-moltenvk force=yes   # Force rebuild MoltenVK (5-10 min)"
    echo "  just build-windows-templates force=yes # Force rebuild Windows templates (5-10 min)"
    echo "  just templates-android force=yes # Force rebuild Android templates (15-25 min)"
        echo "  just ios-build-template force=yes  # Force rebuild iOS templates (20-30 min)"
    echo "  just build-editor force=yes        # Force rebuild Godot editor (20-30 min)"
    echo "  just build-toolchain force=yes    # Force rebuild complete toolchain (45-75 min)"
    echo ""
    echo "🚀 LAUNCH COMMANDS"
    echo "  just run-editor                  # Editor (shows session ID for test creation) 🚀 (Task-329)"
    echo "  just run-android                 # Android debug (shows session ID)"
    echo "  just launch-android              # Launch existing Android app"
    echo ""
    echo "🧪 CROSS-PLATFORM TESTING"
    echo "  just test                        # Multi-platform test suite (main config) with unified summary"
    echo "  just test-all                    # Multi-platform with target selection + unified summary"
    echo "  just test-all CONFIG             # Multi-platform test specific config on desktop + android"
    echo "  just test-android CONFIG         # Android testing with fzf selection"
    echo "  just test-desktop CONFIG         # Desktop testing with fzf selection"
    echo "  just test-ios CONFIG             # iOS testing with fzf selection (NEW!)"
    echo "  just test-ios-iphone CONFIG      # iOS testing on iPhone device (NEW!)"
    echo "  just test-ios-ipad CONFIG        # iOS testing on iPad device (NEW!)"
    echo ""
    echo "✅ VALIDATION & SYNTAX CHECKING"
    echo "  just validate                    # Complete validation (format + syntax + runtime)"
    echo "  just validate-gdscript           # Fast syntax validation (3 seconds)"
    echo "  just validate-godot              # Runtime validation (10-15 sec)"
    echo ""
    echo "📖 For full interactive help: just help"

