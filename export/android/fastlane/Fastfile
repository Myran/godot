# Fastfile for GameTwo Android deployment
# Usage: fastlane [lane] from export/android directory

default_platform(:android)

# Helper: Extract version from export_presets.cfg (single source of truth)
def get_version_from_export_presets
  # From export/android/fastlane/ go up 3 levels to repo root, then into project/
  presets_path = File.expand_path('../../../project/export_presets.cfg', __dir__)

  unless File.exist?(presets_path)
    UI.user_error!("export_presets.cfg not found at #{presets_path}")
  end

  content = File.read(presets_path)

  # Extract Android version (first occurrence)
  version_code = content.match(/^version\/code=(\d+)/)&.[](1)
  version_name = content.match(/^version\/name="([^"]+)"/)&.[](1)

  {
    code: version_code,
    name: version_name
  }
end

# Helper: Get next version code by checking all tracks on Play Store
def get_next_version_code(json_key_file, package_name)
  tracks = ['internal', 'alpha', 'beta', 'production']
  max_version = 0

  tracks.each do |track|
    begin
      codes = google_play_track_version_codes(
        track: track,
        json_key: json_key_file,
        package_name: package_name
      )
      track_max = codes.max || 0
      max_version = [max_version, track_max].max
    rescue => e
      UI.message("Could not fetch #{track} track: #{e.message}")
    end
  end

  max_version + 1
end

# Helper: Update version code in export_presets.cfg
def update_version_code_in_presets(new_code)
  presets_path = File.expand_path('../../../project/export_presets.cfg', __dir__)
  content = File.read(presets_path)
  updated = content.gsub(/^version\/code=\d+/, "version/code=#{new_code}")
  File.write(presets_path, updated)
  UI.success("Updated export_presets.cfg with version code: #{new_code}")
end

# Helper: Upload to Play Store
# Use draft:true for first upload to a track (app not yet published)
def upload_to_track(track:, aab:, json_key:, package_name:, draft: false)
  status = draft ? 'draft' : 'completed'
  UI.message("📦 Uploading to #{track} track [#{status}]")

  upload_to_play_store(
    track: track,
    aab: aab,
    json_key: json_key,
    package_name: package_name,
    release_status: status,
    skip_upload_apk: true,
    skip_upload_screenshots: true,
    skip_upload_images: true,
    skip_upload_metadata: true
  )

  if draft
    UI.success("✅ Uploaded as draft - go to Play Console to start rollout")
  end
end

platform :android do
  # Path to Google Play service account key (absolute path to fastlane directory)
  json_key_file = File.expand_path('fastlaneaccountkey.json', __dir__)

  # App configuration
  package_name = 'com.primaryhive.gametwo'

  #################################################
  # Internal Testing Track (up to 100 testers)
  # Usage: fastlane internal [draft:true]
  #################################################
  lane :internal do |options|
    version = get_version_from_export_presets
    UI.message("📦 Uploading v#{version[:name]} (#{version[:code]})")

    upload_to_track(
      track: 'internal',
      aab: 'gametwo.aab',
      json_key: json_key_file,
      package_name: package_name,
      draft: options[:draft] || false
    )
  end

  #################################################
  # Alpha (Closed Testing Track)
  # Usage: fastlane alpha [draft:true]
  #################################################
  lane :alpha do |options|
    version = get_version_from_export_presets
    UI.message("📦 Uploading v#{version[:name]} (#{version[:code]})")

    upload_to_track(
      track: 'alpha',
      aab: 'gametwo.aab',
      json_key: json_key_file,
      package_name: package_name,
      draft: options[:draft] || false
    )
  end

  #################################################
  # Beta (Open Testing Track)
  # Usage: fastlane beta [draft:true]
  #################################################
  lane :beta do |options|
    version = get_version_from_export_presets
    UI.message("📦 Uploading v#{version[:name]} (#{version[:code]})")

    upload_to_track(
      track: 'beta',
      aab: 'gametwo.aab',
      json_key: json_key_file,
      package_name: package_name,
      draft: options[:draft] || false
    )
  end

  #################################################
  # Production Track - Use with caution!
  # Usage: fastlane production [draft:true]
  #################################################
  lane :production do |options|
    version = get_version_from_export_presets
    UI.important("🚀 PRODUCTION: v#{version[:name]} (#{version[:code]})")

    upload_to_track(
      track: 'production',
      aab: 'gametwo.aab',
      json_key: json_key_file,
      package_name: package_name,
      draft: options[:draft] || false
    )
  end

  #################################################
  # Deploy to specified track
  # Usage: fastlane deploy track:internal [draft:true]
  #################################################
  lane :deploy do |options|
    track = options[:track] || 'internal'
    version = get_version_from_export_presets
    UI.message("📦 Uploading v#{version[:name]} (#{version[:code]})")

    upload_to_track(
      track: track,
      aab: 'gametwo.aab',
      json_key: json_key_file,
      package_name: package_name,
      draft: options[:draft] || false
    )
  end

  #################################################
  # Validate service account key
  #################################################
  lane :validate do
    validate_play_store_json_key(
      json_key: json_key_file
    )
  end

  #################################################
  # Show current version from export_presets.cfg
  # Useful for verification before upload
  #################################################
  lane :version do
    version = get_version_from_export_presets
    UI.success("Current version from export_presets.cfg:")
    UI.message("  Version Code: #{version[:code]}")
    UI.message("  Version Name: #{version[:name]}")
    version
  end

  #################################################
  # Bump version code to next available
  # Fetches max version from all Play Store tracks
  # and increments by 1, then updates export_presets.cfg
  #################################################
  lane :bump_version do
    UI.message("🔍 Fetching current version codes from Play Store...")
    next_code = get_next_version_code(json_key_file, package_name)
    UI.success("📈 Next version code: #{next_code}")
    update_version_code_in_presets(next_code)
    next_code
  end

  #################################################
  # Get next version code (read-only, no update)
  #################################################
  lane :next_version do
    UI.message("🔍 Fetching current version codes from Play Store...")
    next_code = get_next_version_code(json_key_file, package_name)
    UI.success("📈 Next available version code: #{next_code}")
    next_code
  end
end
