# ================================
# Android Release Build Configuration
# Copy to .env and fill in your values
# DO NOT COMMIT .env TO VERSION CONTROL
#
# Only Release configuration needed - debug uses Android default
# ================================

# Release Keystore Configuration
# IMPORTANT: Godot requires absolute paths for keystore files
# Update this path to match your actual project location
GODOT_ANDROID_KEYSTORE_RELEASE_PATH=/path/to/your/gametwo/keystore/gametwo-release.keystore

# Release keystore alias (set when creating keystore)
GODOT_ANDROID_KEYSTORE_RELEASE_USER=gametwo

# Release keystore password (REQUIRED - replace with your actual password)
GODOT_ANDROID_KEYSTORE_RELEASE_PASSWORD=""

# Optional: Script encryption (uncomment if needed)
# GODOT_SCRIPT_ENCRYPTION_KEY=""

# Optional: Build metadata (uncomment if needed)
# ANDROID_VERSION_CODE="42"
# ANDROID_VERSION_NAME="1.0.0"
# ANDROID_PACKAGE_NAME="com.primaryhive.gametwo"

# ================================
# Setup Instructions:
#
# 1. Copy this template to .env: cp .env.template .env
# 2. Edit .env and set BOTH:
#    - GODOT_ANDROID_KEYSTORE_RELEASE_PATH (absolute path to your keystore)
#    - GODOT_ANDROID_KEYSTORE_RELEASE_PASSWORD (your keystore password)
# 3. Example path: /Users/yourname/repos/gametwo/keystore/gametwo-release.keystore
# 4. Build with: just build-all-android
#
# To create new release keystore:
# keytool -genkey -v -keystore keystore/gametwo-release.keystore -alias gametwo -keyalg RSA -keysize 2048 -validity 10000
#
# IMPORTANT: Use absolute paths - Godot requires them for keystore files!
# ================================